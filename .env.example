# Hytta — Required environment variables
# Copy this file to .env.local and fill in real values.
# The app refuses to start unless every required variable below is set.
# (The cottage's own display name is NOT an env var — it is set on first run
#  via the /setup screen and stored in the database.)

# ---------------------------------------------------------------------------
# Database — Cloudflare D1
# ---------------------------------------------------------------------------
# There is no DATABASE_URL: the app talks to the D1 binding `DB`.
#
# For remote Cloudflare commands, provision once with `wrangler d1 create hytta`,
# then put the returned UUID here. `bun run db:migrate:remote` and
# the Cloudflare build/deploy scripts generate ignored wrangler.local.jsonc
# files from it.
# Do not paste account-specific database IDs into tracked Wrangler config.
HYTTA_D1_DATABASE_ID=
#
# Apply migrations with `bun run db:migrate` (local) / `db:migrate:remote`.
# Locally, `next dev` and the tests use an in-memory/Miniflare D1 automatically.

# ---------------------------------------------------------------------------
# Auth.js core
# ---------------------------------------------------------------------------
# Generate with: openssl rand -base64 32
AUTH_SECRET=replace-me-with-32-bytes-of-random-base64

# Public origin of the running app. Used by Auth.js for callback URLs and by
# magic-link / invite / reset emails to construct absolute URLs. Use HTTPS in
# production.
AUTH_URL=http://localhost:3000

# Comma-separated emails that are auto-promoted to admin on every sign-in.
# Useful for bootstrapping admins without a DB edit. Note: the first admin is
# now chosen on the /setup screen (you enter their email there), so this is only
# needed for additional auto-promoted admins.
ADMIN_EMAILS=

# ---------------------------------------------------------------------------
# Outbound email (magic-link sign-ins, invites, password resets)
# ---------------------------------------------------------------------------
# Provider-agnostic. EMAIL_PROVIDER selects the transport; Resend is the
# recommended default and the only one that runs on the Cloudflare Worker.
# Delivery is recommended but NOT enforced — with nothing configured, mail is
# logged to the server console so local flows still work.
#
#   resend  (default) — HTTP API, works on Cloudflare. Set RESEND_API_KEY.
#   smtp              — nodemailer; Node runtime only (self-host / `bun run
#                       start`), NOT the Worker. Set SMTP_* and `bun add nodemailer`.
EMAIL_PROVIDER=resend

# EMAIL_FROM must match a verified sender domain. The display name is a fallback —
# outbound mail uses the cottage name (from /setup) as the From name.
EMAIL_FROM="Hytta <noreply@example.no>"

# Resend (https://resend.com): verify a domain, mint a key at /api-keys.
# Leave empty in dev to log mail to the console.
RESEND_API_KEY=

# SMTP (only when EMAIL_PROVIDER=smtp).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=false

# ---------------------------------------------------------------------------
# Test login (optional)
# ---------------------------------------------------------------------------
# Set BOTH to create a normal member "test user" with a password you can sign
# in with at /login/credentials. It is reconciled lazily on the first request
# after a (re)start: change values to update it, remove them to delete the
# account. Use an email that no real user has. This is the only env-defined account.
TEST_USER_EMAIL=
TEST_USER_PASSWORD=
# Role for the test user: "admin", "manager", or anything else / empty = a
# normal member.
TEST_USER_ROLE=
