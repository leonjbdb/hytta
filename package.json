{
  "name": "hytta",
  "version": "0.1.0",
  "private": true,
  "license": "(MIT OR Apache-2.0)",
  "type": "module",
  "scripts": {
    "dev": "bun run scripts/dev.ts",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "bun run scripts/test.ts",
    "test:watch": "bun test --watch",
    "test:i18n": "bun test tests/i18n",
    "preview": "bun run scripts/preview.ts",
    "deploy:do": "wrangler deploy --config workers/booking-do/wrangler.jsonc",
    "deploy": "bun run deploy:do && opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "cf-typegen": "wrangler types",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "wrangler d1 migrations apply hytta --local",
    "db:migrate:remote": "wrangler d1 migrations apply hytta --remote",
    "demo": "bun run src/db/demo.ts",
    "db:reset": "bun run scripts/db-reset.ts",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@auth/drizzle-adapter": "^1.11.2",
    "@dnd-kit/core": "^6.3.1",
    "@opennextjs/cloudflare": "1.19.11",
    "@tanstack/query-sync-storage-persister": "^5.100.8",
    "@tanstack/react-query": "^5.100.8",
    "@tanstack/react-query-persist-client": "^5.100.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^1.14.0",
    "next": "^16.2.4",
    "next-auth": "5.0.0-beta.31",
    "next-intl": "^4.11.0",
    "react": "^19.2.5",
    "react-day-picker": "^9.14.0",
    "react-dom": "^19.2.5",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.4.2"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "4.20260608.1",
    "@socketsecurity/bun-security-scanner": "1.1.2",
    "@tailwindcss/postcss": "^4.2.4",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "bun-types": "^1.3.13",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.3.0",
    "eslint-config-next": "^16.2.4",
    "tailwindcss": "^4.2.4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3",
    "wrangler": "4.98.0"
  },
  "engines": {
    "bun": ">=1.2"
  },
  "trustedDependencies": [
    "@parcel/watcher",
    "@swc/core",
    "unrs-resolver"
  ]
}
